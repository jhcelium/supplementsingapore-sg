---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadMarkdown } from "../lib/content";
import site from "../../data/site.json";

const home = loadMarkdown("home.md");

const websiteJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Supplements Singapore",
  "url": "https://supplementsingapore.neoi.jp/",
  "description": "A structured guide to supplements in Singapore: health supplements, pharmacy vs online buying, label transparency, and regulation context.",
});
---
<BaseLayout
  fullTitle="Supplements Singapore | Practical Guide to Health Supplements"
  description="A structured guide to supplements in Singapore: health supplements, pharmacy vs online buying, label transparency, and regulation context."
  path="/"
>
  <script type="application/ld+json" set:html={websiteJsonLd}></script>

  <h1>Supplements Singapore: A Practical Guide to Health Supplements</h1>

  <div class="disclaimer">
    This site provides general educational information on health supplements in Singapore.
    It is not medical advice, diagnosis, or treatment recommendation.
    Always speak with a qualified clinician about your own situation.
  </div>

  <figure class="guide-figure">
    <img
      src="/supplements-singapore-guide.png"
      alt="Supplements Singapore: visual overview covering pharmacy vs online buying, label comparison, regulation context, and long-term routine perspective"
      class="guide-img"
    />
    <figcaption>Visual overview of this guide — sections covered below in full.</figcaption>
  </figure>

  <article set:html={home.html} />

  <section>
    <h2>Start here</h2>
    <p>These specialist guides go deeper on specific topics covered in this overview.</p>
    <ul>
      <li><a href="https://healthsupplements.neoi.jp/">Health supplements guidance</a> — understanding supplement categories and label conventions</li>
      <li><a href="https://supplementshop.neoi.jp/">Supplement shopping framework</a> — a structured approach to evaluating sellers and products</li>
      <li><a href="https://onlinesupplements.neoi.jp/">Online buying verification</a> — how to assess online listings before purchasing</li>
      <li><a href="https://naturalsupplements.neoi.jp/">Natural label clarity</a> — what "natural" means and does not mean on supplement labels</li>
    </ul>
  </section>

  <section>
    <h2>Explore related topics</h2>
    <ul>
      {site.exploreLinks.map((link) => (
        <li><a href={link.url}>{link.label}</a></li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Official Neoi Supplement Site</h2>
    <p>
      For product information and brand details, visit the official Neoi supplement site.
    </p>
    <p>
      <a href="https://supplement.neoi.jp/en" target="_blank" rel="noopener" class="official-link">
        Visit Official Neoi Supplement Site →
      </a>
    </p>
  </section>
</BaseLayout>
