---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadMarkdown } from "../lib/content";

const about = loadMarkdown("about.md");

const orgJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Supplements Singapore",
  "url": "https://supplementsingapore.neoi.jp/",
});
---
<BaseLayout
  fullTitle="About | Supplements Singapore Guide"
  description="Purpose and approach behind Supplements Singapore: non-commercial, label-focused education."
  path="/about/"
>
  <script type="application/ld+json" set:html={orgJsonLd}></script>

  <h1>About Supplements Singapore</h1>

  <article set:html={about.html} />

  <section>
    <h2>Related specialist guides</h2>
    <p>This site links to a set of specialist guides that go deeper on specific areas of the supplements singapore topic.</p>
    <ul>
      <li>
        <a href="https://healthsupplements.neoi.jp/">Health supplements guidance</a> —
        a closer look at supplement categories, ingredient conventions, and how to read health supplement labels in Singapore.
      </li>
      <li>
        <a href="https://supplementshop.neoi.jp/">Supplement shopping framework</a> —
        a structured process for evaluating sellers and products before you buy supplements singapore, whether in-store or online.
      </li>
      <li>
        <a href="https://onlinesupplements.neoi.jp/">Online buying verification</a> —
        how to assess supplements singapore online listings: seller credibility, product page completeness, and HSA label alignment.
      </li>
      <li>
        <a href="https://naturalsupplements.neoi.jp/">Natural label clarity</a> —
        what "natural" means and does not mean on supplement labels, and how to evaluate natural supplements singapore products by ingredient rather than descriptor.
      </li>
    </ul>
  </section>

  <figure class="guide-figure">
    <img
      src="/supplements-learning-path.png"
      alt="Your 3-Step Journey to Smart Supplement Choices: a structured learning path covering foundation knowledge, evaluation skills, and practical decision-making tools for supplements in Singapore"
      class="guide-img"
    />
    <figcaption>A suggested 3-step reading path for first-time visitors to this site.</figcaption>
  </figure>

  <section>
    <h2>Official Neoi Supplement Site</h2>
    <p>
      For product information and brand details, visit the official Neoi supplement site.
    </p>
    <p>
      <a href="https://supplement.neoi.jp/en" target="_blank" rel="noopener" class="official-link">
        Visit Official Neoi Supplement Site →
      </a>
    </p>
  </section>
</BaseLayout>
