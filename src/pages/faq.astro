---
import BaseLayout from "../layouts/BaseLayout.astro";
import { loadMarkdown } from "../lib/content";

const loaded = loadMarkdown("faq.md");
const { frontmatter, html } = loaded;
const faqItems: Array<{ q: string; a: string }> = frontmatter.faq ?? [];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.slice(0, 4).map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a },
  })),
});
---
<BaseLayout
  fullTitle="FAQ | Supplements Singapore"
  description="Common questions about buying and understanding supplements in Singapore."
  path="/faq/"
>
  <script type="application/ld+json" set:html={faqJsonLd}></script>

  <h1>Supplements Singapore FAQ</h1>

  <div class="disclaimer">
    General educational information only. Not medical advice.
    If you have questions about your personal situation, consult a qualified clinician or pharmacist.
  </div>

  <article set:html={html} />

  <figure class="guide-figure">
    <img
      src="/supplements-knowledge-check.png"
      alt="Knowledge Check: 3-step quiz to test your understanding of health supplements in Singapore — covering foundation knowledge, evaluation skills, and practical application"
      class="guide-img"
    />
    <figcaption>Knowledge check: use these quizzes to verify your understanding before making supplement decisions.</figcaption>
  </figure>

  <section>
    <h2>Specialist guides</h2>
    <p>For more depth on specific topics raised in these questions:</p>
    <ul>
      <li><a href="https://healthsupplements.neoi.jp/">Health supplements guidance</a> — supplement categories and label conventions</li>
      <li><a href="https://supplementshop.neoi.jp/">Supplement shopping framework</a> — structured evaluation before purchase</li>
      <li><a href="https://onlinesupplements.neoi.jp/">Online buying verification</a> — assessing supplements singapore online listings</li>
      <li><a href="https://naturalsupplements.neoi.jp/">Natural label clarity</a> — understanding "natural" on supplement labels</li>
    </ul>
  </section>

  <section>
    <h2>Official Neoi Supplement Site</h2>
    <p>
      For product information and brand details, visit the official Neoi supplement site.
    </p>
    <p>
      <a href="https://supplement.neoi.jp/en" target="_blank" rel="noopener" class="official-link">
        Visit Official Neoi Supplement Site →
      </a>
    </p>
  </section>
</BaseLayout>
