---
import Seo from "../components/Seo.astro";
import site from "../../data/site.json";
import "../styles/editorial.css";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  fullTitle?: string;
}
const { title, description, path, fullTitle } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo title={title} description={description} path={path} fullTitle={fullTitle} />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/faq">FAQ</a>
      </nav>
      <a href="https://supplement.neoi.jp/en" target="_blank" rel="noopener" class="header-logo" aria-label="Official Neoi Supplement Site">
        <img src="/neoi-logo.png" alt="supplement.neoi.jp" />
      </a>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div>{site.siteName}</div>
      <div style="margin-top:4px">Educational content only. Not medical or treatment advice.</div>
      <div style="margin-top:8px">
        <a href={site.officialSite} target="_blank" rel="noopener noreferrer">
          Official Neoi Site
        </a>
      </div>
    </footer>
  </body>
</html>
